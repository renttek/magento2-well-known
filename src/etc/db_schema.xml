<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="renttek_wellknown_content">
        <column name="content_id" xsi:type="int"        nullable="false" unsigned="true" identity="true"/>
        <column name="identifier" xsi:type="varchar"    nullable="false" length="255"/>
        <column name="content"    xsi:type="mediumtext" nullable="false"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="content_id"/>
        </constraint>

        <index referenceId="RENTTEK_WELLKNOWN_CONTENT_IDENTIFIER" indexType="btree">
            <column name="identifier"/>
        </index>
    </table>

    <table name="renttek_wellknown_content_store">
        <column name="store_id"   xsi:type="smallint" nullable="false" unsigned="true"/>
        <column name="content_id" xsi:type="int"      nullable="false" unsigned="true"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="store_id"/>
            <column name="content_id"/>
        </constraint>

        <constraint xsi:type="foreign"
                    referenceId="FK__CONTENT_STORE__CONTENT"
                    table="renttek_wellknown_content_store"
                    column="content_id"
                    referenceTable="renttek_wellknown_content"
                    referenceColumn="content_id"
                    onDelete="CASCADE"/>

        <constraint xsi:type="foreign"
                    referenceId="FK__CONTENT_STORE__STORE"
                    table="renttek_wellknown_content_store"
                    column="store_id"
                    referenceTable="store"
                    referenceColumn="store_id"
                    onDelete="CASCADE"/>
    </table>
</schema>
