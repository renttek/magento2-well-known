<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">renttekwellknown_content_form.renttekwellknown_content_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Content Information</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="save" class="Renttek\WellKnown\Block\Adminhtml\Content\Edit\SaveButton"/>
            <button name="back" class="Renttek\WellKnown\Block\Adminhtml\Content\Edit\BackButton"/>
        </buttons>
        <namespace>renttekwellknown_content_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>renttekwellknown_content_form.renttekwellknown_content_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="renttekwellknown_content_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="renttekwellknown/content/save"/>
        </settings>
        <dataProvider class="Renttek\WellKnown\Model\DataProvider\ContentDataProvider" name="renttekwellknown_content_form_data_source">
            <settings>
                <requestFieldName>content_id</requestFieldName>
                <primaryFieldName>content_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label>General Information</label>
        </settings>
        <field name="content_id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
            </settings>
        </field>
        <field name="identifier" sortOrder="10" formElement="input">
            <settings>
                <label translate="true">Identifier</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="type" sortOrder="20" formElement="select">
            <settings>
                <label translate="true">Type</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Renttek\WellKnown\Model\Config\Source\ContentType"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="content" sortOrder="30" formElement="textarea">
            <settings>
                <label translate="true">Content</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
    </fieldset>
</form>
